{
  "expo": {
    "name": "Mileage Tracker AI",
    "slug": "mileage-tracker-ai",
    "version": "1.1.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/mileage-tracker-ai"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mileagetracker",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "owner": "multisystems",
    "description": "The smartest mileage tracking app powered by AI. Automatically track your business drives, maximize IRS tax deductions, scan receipts with OCR, and generate compliant tax reports. Perfect for freelancers, real estate agents, sales professionals, rideshare drivers, and small business owners. Features include GPS auto-detection, AI trip classification, expense tracking, and CPA-ready PDF reports.",
    "githubUrl": "https://github.com/multisystems/mileage-tracker-ai",
    "primaryColor": "#10B981",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090B"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.multisystems.mileagetrackerai",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Track your drives for tax-deductible mileage records",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Auto-detect trip starts and stops in background",
        "NSCameraUsageDescription": "Scan receipts to automatically track business expenses",
        "NSPhotoLibraryUsageDescription": "Upload receipt photos from your gallery",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.multisystems.mileagetrackerai",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#09090B"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Mileage Tracker AI to access your location to automatically track your business drives in the background.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "mileage-tracker-ai"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}