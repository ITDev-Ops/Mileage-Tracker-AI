  "layout_guidelines": {
    "safe_area": "Always wrap screen content in SafeAreaView (except full-screen maps/images)",
    "padding": "Use 16px horizontal padding for standard screens",
    "typography": "Use pure white for primary text, zinc-400 for secondary. Avoid pure black backgrounds for cards; use zinc-900."
  },
  "instructions_to_main_agent": [
    "Use 'react-native' components: View, Text, StyleSheet, Pressable, ScrollView, FlatList, Image, SafeAreaView, Modal, TextInput.",
    "Use 'expo-router' for navigation (Stack and Tabs).",
    "Use '@expo/vector-icons' for icons.",
    "Do NOT use 'div', 'span', 'className'. This is React Native.",
    "Implement 'StyleSheet.create' for all styles.",
    "For the 'Map', use a placeholder Image if 'react-native-maps' is complex to set up in this environment, but prefer the real map if possible.",
    "Ensure 'StatusBar' is set to 'light-content'.",
    "Create a 'components' folder for reusable UI (Button, Input, Card).",
    "Create a 'constants/theme.js' file to export colors and spacing."
  ],
  "universal_guidelines": [
    "Always use flex: 1 for root containers.",
    "Touch targets must be at least 44x44 points.",
    "Text must not scale indefinitely; consider using 'maxFontSizeMultiplier'.",
    "Images should use 'contentFit=\"cover\"' (expo-image) or 'resizeMode=\"cover\"' (react-native Image).",
    "Use 'KeyboardAvoidingView' for forms."
  ]
}